<Window x:Class="Project_5010.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Momentum - Login" Height="420" Width="420"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Momentum"
                   FontSize="30"
                   FontWeight="Bold"
                   Margin="0,0,0,18"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Username"/>
            <TextBox x:Name="UsernameTextBox" Height="32" Margin="0,6,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Password"/>
            <PasswordBox x:Name="PasswordBox" Height="32" Margin="0,6,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,12">
            <Button Content="Login" Width="120" Height="36" Margin="0,0,10,0"
                    Click="Login_Click"/>
            <Button Content="Register" Width="120" Height="36"
                    Click="Register_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="4" x:Name="StatusText"
                   Foreground="Gray"
                   TextWrapping="Wrap"/>
    </Grid>
</Window>