<Window x:Class="Project_5010.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Momentum"
        Width="1380"
        Height="860"
        MinWidth="1180"
        MinHeight="760"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ShellBg}">

    <Window.Resources>
        <!-- Nav button style — uses DynamicResource so it responds to theme changes -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource NavHoverBg}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource NavHoverBorder}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HeaderPillStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="16,10"/>
        </Style>

        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Background" Value="{DynamicResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource ShellBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="270"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Margin="18"
                Background="{DynamicResource SidebarBg}"
                BorderBrush="{DynamicResource BorderSoft}"
                BorderThickness="1"
                CornerRadius="26">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Brand logo -->
                <StackPanel Margin="22,22,22,14">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="44"
                                Height="44"
                                CornerRadius="14"
                                Background="{DynamicResource AppAccent}">
                            <TextBlock Text="✦"
                                       Foreground="White"
                                       FontSize="20"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="Momentum"
                                       FontSize="22"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock x:Name="BrandSubtitleText"
                                       Text="Train smarter"
                                       FontSize="12"
                                       Foreground="{DynamicResource BodyTextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation buttons -->
                <StackPanel Grid.Row="1" Margin="22,6,22,22">
                    <Button x:Name="DashboardNavButton"
                            Style="{StaticResource NavButtonStyle}"
                            Click="DashboardNavButton_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE80F;"
                                       FontSize="16"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Dashboard"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button x:Name="WorkoutsNavButton"
                            Style="{StaticResource NavButtonStyle}"
                            Click="WorkoutsNavButton_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE8D4;"
                                       FontSize="16"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Workouts"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button x:Name="LibraryNavButton"
                            Style="{StaticResource NavButtonStyle}"
                            Click="LibraryNavButton_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE8F1;"
                                       FontSize="16"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Library"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button x:Name="CaloriesNavButton"
                            Style="{StaticResource NavButtonStyle}"
                            Click="CaloriesNavButton_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE77F;"
                                       FontSize="16"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Calories"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>

                    <Button x:Name="SettingsNavButton"
                            Style="{StaticResource NavButtonStyle}"
                            Click="SettingsNavButton_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       FontFamily="Segoe MDL2 Assets"
                                       Text="&#xE713;"
                                       FontSize="16"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="Settings"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Button>
                </StackPanel>

                <!-- Daily motivational quote -->
                <Border Grid.Row="2"
                        Margin="22,0,22,22"
                        Padding="18"
                        Background="{DynamicResource AccentSoftBrush}"
                        BorderBrush="{DynamicResource BorderSoft}"
                        BorderThickness="1"
                        CornerRadius="18">
                    <StackPanel>
                        <TextBlock Text="Daily Momentum"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock x:Name="ShellJokeText"
                                   TextWrapping="Wrap"
                                   Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource BodyTextBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main content area -->
        <Grid Grid.Column="1" Margin="10,18,18,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header bar -->
            <Grid Margin="6,4,6,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="340"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="PageTitleText"
                               Text="Dashboard"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock x:Name="PageSubtitleText"
                               Text="Track your momentum across the week"
                               Margin="0,4,0,0"
                               FontSize="14"
                               Foreground="{DynamicResource BodyTextBrush}"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Margin="18,0,18,0"
                        Background="{DynamicResource CardBg}"
                        BorderBrush="{DynamicResource BorderSoft}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Height="46">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="&#x1F50D;"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="16,0,8,0"
                                   Foreground="{DynamicResource TextMuted}"/>
                        <TextBlock Grid.Column="1"
                                   Text="Find something here..."
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextMuted}"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource HeaderPillStyle}"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="38"
                                Height="38"
                                Background="{DynamicResource AccentSoftBrush}"
                                CornerRadius="12"
                                VerticalAlignment="Center">
                            <TextBlock Text="&#x1F464;"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="HeaderUserNameText"
                                       Text="Athlete"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock x:Name="HeaderSplitText"
                                       Text="PPL split"
                                       FontSize="12"
                                       Foreground="{DynamicResource BodyTextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- View host -->
            <Border Grid.Row="1"
                    Background="{DynamicResource ShellBg}"
                    CornerRadius="24">
                <ContentControl x:Name="MainContentHost"/>
            </Border>
        </Grid>
    </Grid>
</Window>
