<Window x:Class="Project_5010.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Momentum" Height="720" Width="1200"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush1}" BorderThickness="0,0,1,0">
            <StackPanel Margin="16">

                <StackPanel Orientation="Horizontal" Margin="6,8,6,18">
                    <Border Width="34" Height="34" CornerRadius="10" Background="#1A2433" Margin="0,0,10,0">
                        <TextBlock Text="M" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" FontSize="16"/>
                    </Border>
                    <TextBlock Text="Momentum" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="OVERVIEW" Foreground="{StaticResource MutedTextBrush}" Margin="8,8,0,10" FontSize="12"/>

                <Button Style="{StaticResource SidebarButtonStyle}" Content="Dashboard" Click="Dashboard_Click"/>
                <Button Style="{StaticResource SidebarButtonStyle}" Content="Workouts" Click="Workouts_Click"/>
                <Button Style="{StaticResource SidebarButtonStyle}" Content="Library" Click="Library_Click"/>
                <Button Style="{StaticResource SidebarButtonStyle}" Content="Settings" Click="Settings_Click"/>

                <StackPanel VerticalAlignment="Bottom" Margin="0,30,0,0">
                    <TextBlock Text="v0.1" Foreground="{StaticResource MutedTextBrush}" Margin="8,12,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Main content -->
        <Grid Grid.Column="1" Margin="24">
            <ContentControl x:Name="MainContent"/>
        </Grid>
    </Grid>
</Window>