<UserControl x:Class="Project_5010.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ShellBg}">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="24"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>

        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource InputText}"/>
            <Setter Property="Background" Value="{DynamicResource InputBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SplitRadioStyle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="{DynamicResource InputBg}"
                                BorderBrush="{DynamicResource BorderSoft}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="{TemplateBinding Content}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Text="{TemplateBinding Tag}"
                                               Margin="0,6,0,0"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondary}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Width="22"
                                        Height="22"
                                        CornerRadius="11"
                                        Background="{DynamicResource CardBg}"
                                        BorderBrush="{DynamicResource BorderSoft}"
                                        BorderThickness="1.5"
                                        VerticalAlignment="Top">
                                    <Ellipse x:Name="Dot"
                                             Width="10"
                                             Height="10"
                                             Fill="#6D4AFF"
                                             Visibility="Collapsed"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AccentSoftBg}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#6D4AFF"/>
                                <Setter TargetName="Dot" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Background" Value="#6D4AFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource InputText}"/>
            <Setter Property="Background" Value="{DynamicResource CardBg}"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="18,4,2,8">
            <StackPanel Margin="2,2,0,20">
                <TextBlock Text="Personalize Momentum"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="Your name, body stats, and split are saved locally and loaded on startup."
                           Margin="0,6,0,0"
                           FontSize="14"
                           Foreground="{DynamicResource TextSecondary}"/>
            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="1.1*"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Profile"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Basic identity and body metrics used throughout the app."
                                   Margin="0,4,0,20"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondary}"/>

                        <TextBlock Text="Display name" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="DisplayNameTextBox" Style="{StaticResource InputStyle}" Margin="0,0,0,18"/>

                        <TextBlock Text="Height (cm)" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="HeightTextBox" Style="{StaticResource InputStyle}" Margin="0,0,0,18"/>

                        <TextBlock Text="Weight (kg)" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox x:Name="WeightTextBox" Style="{StaticResource InputStyle}" Margin="0,0,0,18"/>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Age" Style="{StaticResource FieldLabelStyle}"/>
                                <TextBox x:Name="AgeTextBox" Style="{StaticResource InputStyle}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Sex" Style="{StaticResource FieldLabelStyle}"/>
                                <Border Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1" CornerRadius="16" Height="46">
                                    <ComboBox x:Name="SexCombo" Background="Transparent" Foreground="{DynamicResource InputText}"
                                              BorderThickness="0" FontSize="14" Padding="10,0"
                                              VerticalContentAlignment="Center" SelectedIndex="0">
                                        <ComboBoxItem Content="Male"/>
                                        <ComboBoxItem Content="Female"/>
                                    </ComboBox>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Activity Level" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1" CornerRadius="16" Height="46" Margin="0,0,0,18">
                            <ComboBox x:Name="ActivityLevelCombo" Background="Transparent" Foreground="{DynamicResource InputText}"
                                      BorderThickness="0" FontSize="14" Padding="10,0"
                                      VerticalContentAlignment="Center" SelectedIndex="2">
                                <ComboBoxItem Content="Sedentary"/>
                                <ComboBoxItem Content="Light"/>
                                <ComboBoxItem Content="Moderate"/>
                                <ComboBoxItem Content="Active"/>
                                <ComboBoxItem Content="Very Active"/>
                            </ComboBox>
                        </Border>

                        <TextBlock Text="Goal" Style="{StaticResource FieldLabelStyle}"/>
                        <Border Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1" CornerRadius="16" Height="46">
                            <ComboBox x:Name="GoalTypeCombo" Background="Transparent" Foreground="{DynamicResource InputText}"
                                      BorderThickness="0" FontSize="14" Padding="10,0"
                                      VerticalContentAlignment="Center" SelectedIndex="1">
                                <ComboBoxItem Content="Lose Weight"/>
                                <ComboBoxItem Content="Maintain"/>
                                <ComboBoxItem Content="Gain Weight"/>
                                <ComboBoxItem Content="Improve Fitness"/>
                            </ComboBox>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Training split"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="This selection can drive your Library tabs and appears in the shell header."
                                   Margin="0,4,0,20"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondary}"/>

                        <RadioButton x:Name="PplRadioButton" GroupName="SplitGroup" Style="{StaticResource SplitRadioStyle}"
                                     Content="PPL" Tag="Push / Pull / Legs with focused gym-day categories." Checked="SplitRadioButton_Checked"/>
                        <RadioButton x:Name="UpperLowerRadioButton" GroupName="SplitGroup" Style="{StaticResource SplitRadioStyle}"
                                     Content="Upper / Lower" Tag="Alternating upper-body and lower-body training days." Checked="SplitRadioButton_Checked"/>
                        <RadioButton x:Name="FullBodyRadioButton" GroupName="SplitGroup" Style="{StaticResource SplitRadioStyle}"
                                     Content="Full Body" Tag="A compact split for fewer weekly sessions." Checked="SplitRadioButton_Checked"/>
                        <RadioButton x:Name="BroSplitRadioButton" GroupName="SplitGroup" Style="{StaticResource SplitRadioStyle}"
                                     Content="Bro Split" Tag="Single muscle group emphasis across dedicated days." Checked="SplitRadioButton_Checked"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Live preview" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="This is how the shell header will read after saving." Margin="0,4,0,18" FontSize="13" Foreground="{DynamicResource TextSecondary}"/>

                            <Border Background="{DynamicResource AccentSoftBg}" BorderBrush="#E3DBFF" BorderThickness="1" CornerRadius="18" Padding="16">
                                <StackPanel>
                                    <TextBlock x:Name="PreviewNameText" Text="Athlete" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock x:Name="PreviewSplitText" Text="PPL split" Margin="0,6,0,0" FontSize="13" Foreground="#6D4AFF"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="Library effect" Margin="0,18,0,6" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock x:Name="LibraryEffectText" Text="Push / Pull / Legs tabs" FontSize="13" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <Button Content="Save settings" Style="{StaticResource PrimaryButtonStyle}" Click="SaveButton_Click"/>
                            <TextBlock x:Name="StatusTextBlock" Text="" Margin="0,12,0,0" FontSize="13" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- Appearance toggle -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Appearance" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,4"/>
                            <TextBlock Text="Switch between light and dark theme." FontSize="12" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,14"/>
                            <CheckBox x:Name="DarkModeToggle" Content="  Dark Mode" FontSize="14" Foreground="{DynamicResource TextPrimary}" Cursor="Hand"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Account" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                            <TextBlock Text="Signing out returns you to the login screen. Your data stays saved." FontSize="12" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Margin="0,0,0,14"/>
                            <Button Content="Log Out" Height="44" Background="{DynamicResource DangerBg}" Foreground="{DynamicResource DangerColor}" FontSize="14" FontWeight="SemiBold"
                                    BorderThickness="1" BorderBrush="{DynamicResource DangerColor}" Cursor="Hand" Click="LogoutButton_Click">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="14">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
