<UserControl x:Class="Project_5010.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="Settings" FontSize="34" FontWeight="Bold"/>
            <TextBlock Text="Profile info and training split."
                       Foreground="{StaticResource MutedTextBrush}"
                       FontSize="14"/>
        </StackPanel>

        <Border Grid.Row="1" Style="{StaticResource CardBorderStyle}" Width="700" HorizontalAlignment="Left">
            <StackPanel>

                <TextBlock Text="Profile" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,12">
                        <TextBlock Text="Display Name" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBox x:Name="NameTextBox" Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,12">
                        <TextBlock Text="Age" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBox x:Name="AgeTextBox" Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,12">
                        <TextBlock Text="Height (cm)" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBox x:Name="HeightTextBox" Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,12">
                        <TextBlock Text="Weight (kg)" Foreground="{StaticResource MutedTextBrush}"/>
                        <TextBox x:Name="WeightTextBox" Margin="0,6,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2">
                        <TextBlock Text="Training Split" Foreground="{StaticResource MutedTextBrush}"/>
                        <ComboBox x:Name="SplitCombo" Margin="0,6,0,0" SelectedIndex="0">
                            <ComboBoxItem Content="PPL"/>
                            <ComboBoxItem Content="UpperLower"/>
                            <ComboBoxItem Content="FullBody"/>
                            <ComboBoxItem Content="Bro"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <Button Content="Save Settings"
                            Height="36"
                            Padding="14,0"
                            Background="{StaticResource AccentBrush}"
                            Foreground="Black"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="SaveButton_Click"/>

                    <TextBlock x:Name="StatusTextBlock"
                               Margin="12,8,0,0"
                               Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>