<UserControl x:Class="Project_5010.Views.GoalsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="#FFFFFF"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- ========== LEFT: Food Log ========== -->
        <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1"
                CornerRadius="12" Padding="16" Margin="0,0,16,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Today's Food Log" FontSize="20" FontWeight="Bold"
                           Foreground="#111827" Margin="0,0,0,12"/>

                <!-- Food list -->
                <ListBox x:Name="FoodListBox" Grid.Row="1"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,4"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#F9FAFB" BorderBrush="#E5E7EB" BorderThickness="1"
                                    CornerRadius="8" Padding="10,8" Margin="0,0,0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{Binding MealColor}" CornerRadius="4"
                                            Padding="6,2" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding MealType}" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="White"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   FontSize="13" Foreground="#111827"/>
                                        <TextBlock Text="{Binding QuantityLabel}"
                                                   Foreground="#6B7280" FontSize="11"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding CaloriesLabel}"
                                               Foreground="#6D4AFF" FontSize="13" FontWeight="SemiBold"
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <Button Grid.Column="3" Content="✕" FontSize="11"
                                            Background="Transparent" Foreground="#9CA3AF"
                                            BorderThickness="0" Cursor="Hand" Padding="4,2"
                                            Tag="{Binding}" Click="DeleteFood_Click"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Total bar -->
                <Border Grid.Row="2" Background="#F5F3FF" BorderBrush="#6D4AFF" BorderThickness="1"
                        CornerRadius="8" Padding="12,8" Margin="0,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Total today" FontWeight="SemiBold" Foreground="#6D4AFF"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="TotalCaloriesText" Grid.Column="1" Text="0 kcal"
                                   FontSize="16" FontWeight="Bold" Foreground="#6D4AFF"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ========== RIGHT: Summary + Add Form ========== -->
        <StackPanel Grid.Column="1">

            <!-- Calorie Goal Card -->
            <Border Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1"
                    CornerRadius="12" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Calorie Goal" FontSize="18" FontWeight="Bold"
                               Foreground="#111827" Margin="0,0,0,12"/>

                    <!-- Pill stats -->
                    <UniformGrid Columns="3" Margin="0,0,0,12">
                        <Border Background="#F5F3FF" CornerRadius="8" Padding="10,8" Margin="0,0,4,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="CalGoalText" Text="0" FontSize="18" FontWeight="Bold"
                                           Foreground="#6D4AFF" HorizontalAlignment="Center"/>
                                <TextBlock Text="Goal" FontSize="10" Foreground="#6B7280"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#F0FDF4" CornerRadius="8" Padding="10,8" Margin="2,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="CalConsumedText" Text="0" FontSize="18" FontWeight="Bold"
                                           Foreground="#10B981" HorizontalAlignment="Center"/>
                                <TextBlock Text="Eaten" FontSize="10" Foreground="#6B7280"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#FFF7ED" CornerRadius="8" Padding="10,8" Margin="4,0,0,0">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock x:Name="CalRemainingText" Text="0" FontSize="18" FontWeight="Bold"
                                           Foreground="#F59E0B" HorizontalAlignment="Center"/>
                                <TextBlock Text="Left" FontSize="10" Foreground="#6B7280"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Progress bar -->
                    <Border Height="12" Background="#F3F4F6" CornerRadius="6" Margin="0,0,0,6">
                        <Grid HorizontalAlignment="Left">
                            <Border x:Name="DashCalorieFill" Height="12" Width="0"
                                    Background="#6D4AFF" CornerRadius="6"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="CalProgressLabel" Text="0% of daily goal"
                               FontSize="11" Foreground="#6B7280" Margin="0,0,0,4"/>
                    <TextBlock x:Name="CalStatusLabel" Text=""
                               FontSize="12" FontWeight="SemiBold" Foreground="#6D4AFF"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Log Food Form -->
            <Border Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1"
                    CornerRadius="12" Padding="16">
                <StackPanel>
                    <TextBlock Text="Log Food" FontSize="18" FontWeight="Bold"
                               Foreground="#111827" Margin="0,0,0,12"/>

                    <TextBlock Text="Food name" Foreground="#6B7280" FontSize="12" Margin="0,0,0,4"/>
                    <Border Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="1"
                            CornerRadius="6" Height="36" Margin="0,0,0,10">
                        <TextBox x:Name="FoodNameBox" Background="Transparent" Foreground="#111827"
                                 BorderThickness="0" Padding="10,0" VerticalContentAlignment="Center" FontSize="13"/>
                    </Border>

                    <TextBlock Text="Calories (kcal)" Foreground="#6B7280" FontSize="12" Margin="0,0,0,4"/>
                    <Border Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="1"
                            CornerRadius="6" Height="36" Margin="0,0,0,10">
                        <TextBox x:Name="FoodCaloriesBox" Background="Transparent" Foreground="#111827"
                                 BorderThickness="0" Padding="10,0" VerticalContentAlignment="Center" FontSize="13"/>
                    </Border>

                    <TextBlock Text="Meal" Foreground="#6B7280" FontSize="12" Margin="0,0,0,4"/>
                    <Border Background="#F3F4F6" BorderBrush="#E5E7EB" BorderThickness="1"
                            CornerRadius="6" Height="36" Margin="0,0,0,16">
                        <ComboBox x:Name="MealTypeCombo" SelectedIndex="0"
                                  Background="Transparent" Foreground="#111827" BorderThickness="0"
                                  FontSize="13" Padding="8,0" VerticalContentAlignment="Center">
                            <ComboBoxItem Content="Breakfast"/>
                            <ComboBoxItem Content="Lunch"/>
                            <ComboBoxItem Content="Dinner"/>
                            <ComboBoxItem Content="Snack"/>
                        </ComboBox>
                    </Border>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="FoodStatusText" VerticalAlignment="Center"
                                   Margin="0,0,10,0" FontSize="11" Foreground="#6B7280"/>
                        <Button Content="Add Food" Background="#6D4AFF" Foreground="White"
                                FontWeight="SemiBold" FontSize="13" Padding="16,8"
                                BorderThickness="0" Cursor="Hand" Click="AddFood_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
