<UserControl x:Class="Project_5010.Views.LibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:Project_5010.Models"
             Background="Transparent">

    <UserControl.Resources>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource CardBg}"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== LEFT: Exercise List Panel ========== -->
        <Border Grid.Column="0" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1"
                CornerRadius="12" Padding="12" Margin="0,0,16,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <TextBlock Text="Library" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                    <TextBlock Text="+ Custom Exercise" Foreground="#9D84FF" FontSize="13"
                               FontWeight="SemiBold" HorizontalAlignment="Right"
                               VerticalAlignment="Center" Cursor="Hand"
                               MouseLeftButtonDown="CustomExercise_Click"/>
                </Grid>

                <!-- Suggestion Card -->
                <Border Grid.Row="1" Background="{DynamicResource AccentSoftBg}" BorderBrush="#6D4AFF" BorderThickness="1"
                        CornerRadius="8" Padding="12" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock x:Name="SuggestionTitleText" Text="Today's Focus"
                                   FontWeight="Bold" Foreground="#6D4AFF" Margin="0,0,0,2"/>
                        <TextBlock Text="Based on your settings and training split."
                                   Foreground="{DynamicResource TextSecondary}" FontSize="11" Margin="0,0,0,6"/>
                        <ItemsControl x:Name="SuggestionItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat='• {0}'}"
                                               Foreground="{DynamicResource TextPrimary}" FontSize="12" Margin="0,1,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Search Box -->
                <Border Grid.Row="2" Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1"
                        CornerRadius="8" Padding="10,0" Height="36" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#x1F50D;" Foreground="{DynamicResource TextMuted}" VerticalAlignment="Center"
                                   Margin="0,0,8,0" FontSize="13"/>
                        <TextBox x:Name="SearchTextBox" Grid.Column="1"
                                 TextChanged="SearchTextBox_TextChanged"
                                 Background="Transparent" Foreground="{DynamicResource TextPrimary}"
                                 BorderThickness="0" FontSize="13" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Exercise List -->
                <ListBox x:Name="ExercisesListView" Grid.Row="3"
                         SelectionChanged="ExercisesListView_SelectionChanged"
                         Background="Transparent" BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,2"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Grid Cursor="Hand" Background="Transparent">
                                            <Border x:Name="HoverOverlay" Background="{DynamicResource AccentSoftBg}"
                                                    CornerRadius="6" Opacity="0"/>
                                            <Border x:Name="SelectedOverlay" Background="{DynamicResource AccentSoftBrush}"
                                                    CornerRadius="6" Opacity="0"/>
                                            <Border Padding="8">
                                                <ContentPresenter/>
                                            </Border>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="SelectedOverlay" Property="Opacity" Value="1"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:Exercise}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                        Background="{DynamicResource AccentSoftBrush}" Margin="0,0,12,0" VerticalAlignment="Center">
                                    <TextBlock Text="&#x1F3CB;&#xFE0F;" FontSize="16" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Margin="0,0,0,2"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                               FontSize="14" Foreground="{DynamicResource TextPrimary}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Muscle}" Foreground="{DynamicResource TextSecondary}"
                                               FontSize="12" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- ========== RIGHT: Tracker / Custom Panel ========== -->
        <Grid Grid.Column="1" VerticalAlignment="Top">

            <!-- Tracker Panel -->
            <Border x:Name="TrackerPanel" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderSoft}"
                    BorderThickness="1" CornerRadius="12" Padding="20" Visibility="Visible">
                <StackPanel>
                    <TextBlock Text="Exercise Details" FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,4"/>
                    <TextBlock x:Name="DetailNameText" Text="Select an exercise..."
                               FontSize="24" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,24">
                        <Border Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1"
                                CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                            <TextBlock x:Name="DetailEquipText" Text="Equipment: —"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                        </Border>
                        <Border Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1"
                                CornerRadius="6" Padding="8,4" Margin="0,0,8,0">
                            <TextBlock x:Name="DetailPrimaryText" Text="Primary: —"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                        </Border>
                        <Border Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1"
                                CornerRadius="6" Padding="8,4">
                            <TextBlock x:Name="DetailSecondaryText" Text="Secondary: —"
                                       Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
                        </Border>
                    </StackPanel>

                    <!-- Log Performance Card -->
                    <Border Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1"
                            CornerRadius="8" Padding="16" Margin="0,0,0,24">
                        <StackPanel>
                            <TextBlock Text="Log Performance" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" FontSize="14" Margin="0,0,0,12"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="Weight (lbs/kg)" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                                    <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1" CornerRadius="6" Height="32">
                                        <TextBox x:Name="PRWeightTextBox" Background="Transparent"
                                                 Foreground="{DynamicResource TextPrimary}" BorderThickness="0"
                                                 Padding="8,0" VerticalContentAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="4,0,4,0">
                                    <TextBlock Text="Reps" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                                    <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1" CornerRadius="6" Height="32">
                                        <TextBox x:Name="PRRepsTextBox" Background="Transparent"
                                                 Foreground="{DynamicResource TextPrimary}" BorderThickness="0"
                                                 Padding="8,0" VerticalContentAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                    <TextBlock Text="Date" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                                    <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1" CornerRadius="6" Height="32">
                                        <DatePicker x:Name="PRDatePicker" Background="Transparent"
                                                    Foreground="{DynamicResource TextPrimary}" BorderThickness="0"
                                                    VerticalContentAlignment="Center"/>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="PRStatusText" VerticalAlignment="Center"
                                           Margin="0,0,12,0" FontSize="12" FontWeight="SemiBold"/>
                                <Button x:Name="DeletePRButton" Content="Delete"
                                        Background="#EF4444" Foreground="White" FontWeight="SemiBold"
                                        FontSize="13" Padding="12,6" Margin="0,0,8,0"
                                        BorderThickness="0" Cursor="Hand"
                                        Visibility="Collapsed" Click="DeletePRButton_Click"/>
                                <Button x:Name="SavePRButton" Content="Log PR"
                                        Background="#6D4AFF" Foreground="White" FontWeight="SemiBold"
                                        FontSize="13" Padding="16,6" BorderThickness="0"
                                        Cursor="Hand" Click="SavePRButton_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Trophy Room (History)" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,8"/>
                    <ListView x:Name="PRListView" SelectionChanged="PRListView_SelectionChanged"
                              Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimary}"
                              Height="200" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Weight" Width="80"
                                                DisplayMemberBinding="{Binding Weight}"/>
                                <GridViewColumn Header="Reps" Width="60"
                                                DisplayMemberBinding="{Binding Reps}"/>
                                <GridViewColumn Header="Date" Width="100"
                                                DisplayMemberBinding="{Binding Date, StringFormat={}{0:MMM dd, yyyy}}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <!-- Best Lifts summary -->
                    <StackPanel x:Name="BestLiftsPanel" Margin="0,16,0,0">
                        <TextBlock Text="Best Lifts" FontSize="14" FontWeight="Bold"
                                   Foreground="#6D4AFF" Margin="0,0,0,8"/>
                        <TextBlock x:Name="BestLiftsContent" FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"
                                   Text="Select an exercise to see your best lifts."/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Custom Exercise Panel -->
            <Border x:Name="CustomExercisePanel" Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource BorderSoft}"
                    BorderThickness="1" CornerRadius="12" Padding="24" Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="Create Custom Exercise" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Exercise Name" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                            <Border Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1" CornerRadius="6" Height="36" Margin="0,0,0,16">
                                <TextBox x:Name="CustomNameBox" Background="Transparent"
                                         Foreground="{DynamicResource TextPrimary}" BorderThickness="0"
                                         Padding="10,0" VerticalContentAlignment="Center"/>
                            </Border>

                            <TextBlock Text="Exercise Type" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                            <Border Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1" CornerRadius="6" Height="36" Margin="0,0,0,16">
                                <ComboBox x:Name="CustomTypeCombo" Background="Transparent"
                                          Foreground="{DynamicResource TextPrimary}" BorderThickness="0" FontSize="13"
                                          Padding="8,0" VerticalContentAlignment="Center" SelectedIndex="0">
                                    <ComboBoxItem Content="Weight &amp; Reps"/>
                                    <ComboBoxItem Content="Reps Only"/>
                                    <ComboBoxItem Content="Weighted Bodyweight"/>
                                    <ComboBoxItem Content="Assisted Bodyweight"/>
                                    <ComboBoxItem Content="Duration"/>
                                </ComboBox>
                            </Border>

                            <TextBlock Text="Equipment" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                            <Border Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1" CornerRadius="6" Height="36" Margin="0,0,0,16">
                                <ComboBox x:Name="CustomEquipCombo" Background="Transparent"
                                          Foreground="{DynamicResource TextPrimary}" BorderThickness="0" FontSize="13"
                                          Padding="8,0" VerticalContentAlignment="Center" SelectedIndex="0">
                                    <ComboBoxItem Content="None"/>
                                    <ComboBoxItem Content="Barbell"/>
                                    <ComboBoxItem Content="Dumbbell"/>
                                    <ComboBoxItem Content="Machine"/>
                                    <ComboBoxItem Content="Cable"/>
                                    <ComboBoxItem Content="Other"/>
                                </ComboBox>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Primary Muscle" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                            <Border Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1" CornerRadius="6" Height="36" Margin="0,0,0,16">
                                <ComboBox x:Name="CustomPrimaryCombo" Background="Transparent"
                                          Foreground="{DynamicResource TextPrimary}" BorderThickness="0" FontSize="13"
                                          Padding="8,0" VerticalContentAlignment="Center" SelectedIndex="0">
                                    <ComboBoxItem Content="Chest"/>
                                    <ComboBoxItem Content="Back"/>
                                    <ComboBoxItem Content="Legs"/>
                                    <ComboBoxItem Content="Shoulders"/>
                                    <ComboBoxItem Content="Biceps"/>
                                    <ComboBoxItem Content="Triceps"/>
                                    <ComboBoxItem Content="Core"/>
                                    <ComboBoxItem Content="Cardio"/>
                                    <ComboBoxItem Content="Other"/>
                                </ComboBox>
                            </Border>

                            <TextBlock Text="Secondary Muscles" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                            <Border Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1" CornerRadius="6" Height="108" Margin="0,0,0,16">
                                <ListBox x:Name="CustomSecondaryList" Background="Transparent"
                                         Foreground="{DynamicResource TextPrimary}" BorderThickness="0"
                                         SelectionMode="Multiple">
                                    <ListBoxItem Content="Chest"/>
                                    <ListBoxItem Content="Back"/>
                                    <ListBoxItem Content="Legs"/>
                                    <ListBoxItem Content="Shoulders"/>
                                    <ListBoxItem Content="Biceps"/>
                                    <ListBoxItem Content="Triceps"/>
                                </ListBox>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <TextBlock x:Name="CustomFormErrorText" Foreground="#EF4444"
                                   VerticalAlignment="Center" Margin="0,0,16,0" FontSize="12"/>
                        <Button Content="Cancel" Background="Transparent" Foreground="{DynamicResource TextSecondary}"
                                FontWeight="SemiBold" FontSize="14" Padding="16,8"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderSoft}" Cursor="Hand"
                                Margin="0,0,8,0" Click="CancelCustom_Click"/>
                        <Button Content="Save Exercise" Background="#6D4AFF" Foreground="White"
                                FontWeight="SemiBold" FontSize="14" Padding="16,8"
                                BorderThickness="0" Cursor="Hand" Click="SaveCustom_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
