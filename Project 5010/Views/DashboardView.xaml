<UserControl x:Class="Project_5010.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource ShellBg}">

    <UserControl.Resources>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="24"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Margin" Value="0,0,16,16"/>
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="18,4,2,8">
            <StackPanel Margin="2,2,0,20">
                <TextBlock x:Name="WelcomeText"
                           Text="Welcome back"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="A quick look at how your week is moving."
                           Margin="0,6,0,0"
                           FontSize="14"
                           Foreground="{DynamicResource TextSecondary}"/>
            </StackPanel>

            <UniformGrid Columns="5" Margin="0,0,0,6">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Total workouts" Style="{StaticResource MetricLabelStyle}"/>
                        <TextBlock x:Name="TotalWorkoutsText" Text="0" Style="{StaticResource MetricValueStyle}" Margin="0,10,0,0"/>
                        <TextBlock Text="All logged sessions" Margin="0,8,0,0" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Total training time" Style="{StaticResource MetricLabelStyle}"/>
                        <TextBlock x:Name="TotalMinutesText" Text="0m" Style="{StaticResource MetricValueStyle}" Margin="0,10,0,0"/>
                        <TextBlock Text="Across your full history" Margin="0,8,0,0" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Workouts this week" Style="{StaticResource MetricLabelStyle}"/>
                        <TextBlock x:Name="ThisWeekText" Text="0" Style="{StaticResource MetricValueStyle}" Margin="0,10,0,0"/>
                        <TextBlock Text="Since the start of this week" Margin="0,8,0,0" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Active days" Style="{StaticResource MetricLabelStyle}"/>
                        <TextBlock x:Name="ActiveDaysText" Text="0" Style="{StaticResource MetricValueStyle}" Margin="0,10,0,0"/>
                        <TextBlock Text="Distinct days trained this week" Margin="0,8,0,0" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Current streak" Style="{StaticResource MetricLabelStyle}"/>
                        <TextBlock x:Name="StreakText" Text="0" Style="{StaticResource MetricValueStyle}" Margin="0,10,0,0"/>
                        <TextBlock Text="days in a row" Margin="0,8,0,0" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Calorie Summary Row (compact) -->
            <Grid Margin="0,0,0,6" x:Name="CalorieRow">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Daily Goal" Style="{StaticResource MetricLabelStyle}"/>
                        <TextBlock x:Name="CalGoalText" Text="&#x2014;" Style="{StaticResource MetricValueStyle}" Margin="0,6,0,0"/>
                        <TextBlock Text="kcal target" Margin="0,4,0,0" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Consumed today" Style="{StaticResource MetricLabelStyle}"/>
                        <TextBlock x:Name="CalConsumedText" Text="0" Style="{StaticResource MetricValueStyle}" Margin="0,6,0,0"/>
                        <TextBlock Text="kcal logged" Margin="0,4,0,0" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Remaining" Style="{StaticResource MetricLabelStyle}"/>
                        <TextBlock x:Name="CalRemainingText" Text="&#x2014;" Style="{StaticResource MetricValueStyle}" Margin="0,6,0,0"/>
                        <TextBlock x:Name="CalRemainingLabel" Text="kcal left" Margin="0,4,0,0" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Today's progress" Style="{StaticResource MetricLabelStyle}" Margin="0,0,0,8"/>
                        <Border Height="10" Background="{DynamicResource ProgressTrackBg}" CornerRadius="5" Margin="0,0,0,6">
                            <Border x:Name="DashCalorieFill" Height="10" Background="#6D4AFF"
                                    CornerRadius="5" HorizontalAlignment="Left" Width="0"/>
                        </Border>
                        <TextBlock x:Name="CalProgressLabel" Text="Log food in Goals to track" FontSize="12" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Macro Breakdown Card -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,16,6">
                <StackPanel>
                    <TextBlock Text="Today's Macros" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,14"/>
                    <!-- Protein bar -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Protein" FontSize="13" FontWeight="SemiBold" Foreground="#10B981" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Height="10" Background="{DynamicResource ProgressTrackBg}" CornerRadius="5" Margin="8,0">
                            <Border x:Name="ProteinFill" Height="10" Background="#10B981" CornerRadius="5"
                                    HorizontalAlignment="Left" Width="0"/>
                        </Border>
                        <TextBlock x:Name="ProteinLabel" Grid.Column="2" Text="0g / 0g" FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                    </Grid>
                    <!-- Carbs bar -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Carbs" FontSize="13" FontWeight="SemiBold" Foreground="#3B82F6" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Height="10" Background="{DynamicResource ProgressTrackBg}" CornerRadius="5" Margin="8,0">
                            <Border x:Name="CarbsFill" Height="10" Background="#3B82F6" CornerRadius="5"
                                    HorizontalAlignment="Left" Width="0"/>
                        </Border>
                        <TextBlock x:Name="CarbsLabel" Grid.Column="2" Text="0g / 0g" FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                    </Grid>
                    <!-- Fat bar -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Fat" FontSize="13" FontWeight="SemiBold" Foreground="#F59E0B" VerticalAlignment="Center"/>
                        <Border Grid.Column="1" Height="10" Background="{DynamicResource ProgressTrackBg}" CornerRadius="5" Margin="8,0">
                            <Border x:Name="FatFill" Height="10" Background="#F59E0B" CornerRadius="5"
                                    HorizontalAlignment="Left" Width="0"/>
                        </Border>
                        <TextBlock x:Name="FatLabel" Grid.Column="2" Text="0g / 0g" FontSize="12"
                                   Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Activity last 7 days"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Minutes trained per day"
                                           Margin="0,4,0,0"
                                           FontSize="13"
                                           Foreground="{DynamicResource TextSecondary}"/>
                            </StackPanel>
                            <Border Grid.Column="1"
                                    Padding="12,8"
                                    Background="{DynamicResource AccentSoftBg}"
                                    CornerRadius="14">
                                <TextBlock x:Name="WeeklyMinutesText"
                                           Text="0 min this week"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="#6D4AFF"/>
                            </Border>
                        </Grid>

                        <Border Background="{DynamicResource InputBg}" BorderBrush="{DynamicResource BorderSoft}" BorderThickness="1" CornerRadius="20" Padding="18">
                            <ItemsControl x:Name="ActivityItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="7"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="250" Margin="6,0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="30"/>
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0"
                                                       Text="{Binding MinutesLabel}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Bottom"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondary}"
                                                       Margin="0,0,0,6"/>

                                            <Border Grid.Row="1"
                                                    Width="34"
                                                    Height="{Binding BarHeight}"
                                                    Background="#6D4AFF"
                                                    CornerRadius="8"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Bottom"/>

                                            <TextBlock Grid.Row="2"
                                                       Text="{Binding DayLabel}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Type breakdown"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Share of all workouts by type"
                                   Margin="0,4,0,18"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextSecondary}"/>

                        <ItemsControl x:Name="TypeBreakdownItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,18">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding TypeName}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="{Binding Count}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimary}"/>
                                                <TextBlock Text=" workouts"
                                                           FontSize="13"
                                                           Foreground="{DynamicResource TextSecondary}"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="{Binding PercentageLabel}"
                                                   Margin="0,4,0,8"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondary}"/>
                                        <Border Height="10" Background="{DynamicResource ProgressTrackBg}" CornerRadius="5">
                                            <Grid HorizontalAlignment="Left">
                                                <Border Width="{Binding BarWidth}"
                                                        Height="10"
                                                        Background="#6D4AFF"
                                                        CornerRadius="5"/>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <UniformGrid Columns="3">
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Average session" Style="{StaticResource MetricLabelStyle}"/>
                        <TextBlock x:Name="AverageSessionText" Text="0m" Style="{StaticResource MetricValueStyle}" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Favorite type" Style="{StaticResource MetricLabelStyle}"/>
                        <TextBlock x:Name="FavoriteTypeText" Text="—" Style="{StaticResource MetricValueStyle}" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Best day this week" Style="{StaticResource MetricLabelStyle}"/>
                        <TextBlock x:Name="BestDayText" Text="—" Style="{StaticResource MetricValueStyle}" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
