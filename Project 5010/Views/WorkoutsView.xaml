<UserControl x:Class="Project_5010.Views.WorkoutsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page header -->
        <StackPanel Margin="0,0,0,18">
            <TextBlock Text="Workouts" FontSize="34" FontWeight="Bold"/>
            <TextBlock Text="Log training, edit entries, and review your history."
                       Foreground="{StaticResource MutedTextBrush}"
                       FontSize="14"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.15*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Log/Edit workout -->
            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Log / Edit Workout" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <TextBlock Text="Workout Type" Foreground="{StaticResource MutedTextBrush}"/>
                    <ComboBox x:Name="WorkoutTypeCombo" SelectedIndex="0" Margin="0,6,0,12">
                        <ComboBoxItem Content="Cardio"/>
                        <ComboBoxItem Content="Strength"/>
                        <ComboBoxItem Content="Flexibility"/>
                    </ComboBox>

                    <TextBlock Text="Date" Foreground="{StaticResource MutedTextBrush}"/>
                    <DatePicker x:Name="WorkoutDatePicker" Margin="0,6,0,12"/>

                    <TextBlock Text="Time (HH:mm)" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox x:Name="WorkoutTimeTextBox" Margin="0,6,0,12"/>

                    <TextBlock Text="Duration (minutes)" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox x:Name="DurationTextBox" Margin="0,6,0,12"/>

                    <TextBlock Text="Notes" Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBox x:Name="NotesTextBox"
                             Height="90"
                             Margin="0,6,0,12"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="SaveOrUpdateButton"
                                Content="Save Workout"
                                Height="36"
                                Padding="14,0"
                                Background="{StaticResource AccentBrush}"
                                Foreground="Black"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="SaveOrUpdateButton_Click"/>

                        <Button x:Name="ClearButton"
                                Content="Clear"
                                Height="36"
                                Margin="10,0,0,0"
                                Padding="14,0"
                                Background="#1A2433"
                                Foreground="{StaticResource TextBrush}"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="ClearButton_Click"/>

                        <Button x:Name="DeleteButton"
                                Content="Delete"
                                Height="36"
                                Margin="10,0,0,0"
                                Padding="14,0"
                                Background="#2A1A1A"
                                Foreground="{StaticResource TextBrush}"
                                BorderThickness="0"
                                Cursor="Hand"
                                Visibility="Collapsed"
                                Click="DeleteButton_Click"/>
                    </StackPanel>

                    <TextBlock x:Name="StatusTextBlock"
                               Margin="0,12,0,0"
                               Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
            </Border>

            <!-- Right: History -->
            <Border Grid.Column="1" Style="{StaticResource CardBorderStyle}">
                <StackPanel>
                    <TextBlock Text="History" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                    <ListView x:Name="HistoryListView"
                              Height="520"
                              SelectionChanged="HistoryListView_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Date"
                                                Width="170"
                                                DisplayMemberBinding="{Binding Date}"/>
                                <GridViewColumn Header="Type"
                                                Width="110"
                                                DisplayMemberBinding="{Binding Type}"/>
                                <GridViewColumn Header="Duration"
                                                Width="90"
                                                DisplayMemberBinding="{Binding DurationMinutes}"/>
                                <GridViewColumn Header="Notes"
                                                Width="240"
                                                DisplayMemberBinding="{Binding Notes}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <TextBlock Text="Tip: Click an item to edit or delete it."
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>