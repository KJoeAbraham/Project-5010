<Application x:Class="Project_5010.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="LoginWindow.xaml">
    <Application.Resources>

        <!-- Theme-aware brushes (light defaults, swapped by ThemeManager) -->

        <!-- Surfaces -->
        <SolidColorBrush x:Key="ShellBg" Color="#F5F6FA"/>
        <SolidColorBrush x:Key="CardBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SidebarBg" Color="#FFFFFF"/>

        <!-- Text -->
        <SolidColorBrush x:Key="TextPrimary" Color="#1D2435"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#727990"/>
        <SolidColorBrush x:Key="TextMuted" Color="#959CB0"/>

        <!-- Borders -->
        <SolidColorBrush x:Key="BorderSoft" Color="#E8EAF3"/>

        <!-- Inputs -->
        <SolidColorBrush x:Key="InputBg" Color="#F3F4F6"/>
        <SolidColorBrush x:Key="InputText" Color="#333A50"/>

        <!-- Progress -->
        <SolidColorBrush x:Key="ProgressTrackBg" Color="#EEF0F6"/>

        <!-- Accent -->
        <SolidColorBrush x:Key="AppAccent" Color="#6D4AFF"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#F0EBFF"/>
        <SolidColorBrush x:Key="AccentSoftBg" Color="#F5F3FF"/>

        <!-- Status -->
        <SolidColorBrush x:Key="SuccessColor" Color="#10B981"/>
        <SolidColorBrush x:Key="DangerColor" Color="#EF4444"/>
        <SolidColorBrush x:Key="DangerBg" Color="#FEF2F2"/>
        <SolidColorBrush x:Key="SuccessBg" Color="#F0FDF4"/>
        <SolidColorBrush x:Key="WarningBg" Color="#FFFBEB"/>
        <SolidColorBrush x:Key="WarningText" Color="#92400E"/>

        <!-- Nav -->
        <SolidColorBrush x:Key="BodyTextBrush" Color="#6E7386"/>
        <SolidColorBrush x:Key="NavHoverBg" Color="#F6F4FF"/>
        <SolidColorBrush x:Key="NavHoverBorder" Color="#E2DAFF"/>
        <SolidColorBrush x:Key="NavActiveBg" Color="#F0EBFF"/>
        <SolidColorBrush x:Key="NavActiveBorder" Color="#DCCFFF"/>

        <!-- Default Window style -->
        <Style TargetType="Window">
            <Setter Property="Background" Value="{DynamicResource ShellBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

    </Application.Resources>
</Application>
